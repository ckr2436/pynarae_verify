<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="pynarae" translate="label" sortOrder="950">
            <label>Pynarae</label>
        </tab>

        <section id="pynarae_verify"
                 translate="label"
                 type="text"
                 sortOrder="10"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">
            <label>Product Verify</label>
            <tab>pynarae</tab>
            <resource>Pynarae_Verify::config</resource>

            <group id="general"
                   translate="label"
                   type="text"
                   sortOrder="10"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>General</label>

                <field id="enabled"
                       translate="label"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="page_title"
                       translate="label"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Page Title</label>
                </field>

                <field id="intro_text"
                       translate="label"
                       type="textarea"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Intro Text</label>
                </field>

                <field id="first_scan_message"
                       translate="label"
                       type="textarea"
                       sortOrder="40"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>First Scan Message</label>
                </field>

                <field id="repeat_scan_message"
                       translate="label"
                       type="textarea"
                       sortOrder="50"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Repeat Scan Message</label>
                </field>

                <field id="invalid_message"
                       translate="label"
                       type="textarea"
                       sortOrder="60"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Invalid Message</label>
                </field>

                <field id="suspicious_threshold"
                       translate="label"
                       type="text"
                       sortOrder="70"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Suspicious Threshold</label>
                    <comment>When scan count reaches this value, a stronger repeated-scan warning is shown.</comment>
                </field>

                <field id="show_product_sku"
                       translate="label"
                       type="select"
                       sortOrder="80"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Show Product SKU</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="show_batch_no"
                       translate="label"
                       type="select"
                       sortOrder="90"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Show Batch Number</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="show_scan_count"
                       translate="label"
                       type="select"
                       sortOrder="100"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Show Scan Count</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="qr_verify_base_url"
                       translate="label"
                       type="text"
                       sortOrder="110"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>QR Verify Base URL</label>
                    <comment>Optional. Used by CSV generator to build verify_url for QR codes. Leave empty to use current store /verify URL.</comment>
                </field>

                <field id="qr_code_param"
                       translate="label"
                       type="text"
                       sortOrder="120"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>QR Code Parameter Name</label>
                    <comment>Query parameter used in verify_url (for example: code).</comment>
                </field>

                <field id="qr_image_url_template"
                       translate="label"
                       type="text"
                       sortOrder="130"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>QR Image URL Template</label>
                    <comment>Optional. If set, CSV adds qr_image_url column. Supported placeholders: {VERIFY_URL}, {VERIFY_URL_ENCODED}, {CODE}, {CODE_ENCODED}.</comment>
                </field>

                <field id="secure_token_enabled"
                       translate="label"
                       type="select"
                       sortOrder="140"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Encrypted Verify Token</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>If enabled, QR verify URL uses encrypted token instead of plain code.</comment>
                </field>

                <field id="secure_token_key"
                       translate="label"
                       type="obscure"
                       sortOrder="150"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Secure Token Secret Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Required when encrypted verify token is enabled. Use a long random secret and keep it private.</comment>
                </field>

                <field id="secure_token_ttl_days"
                       translate="label"
                       type="text"
                       sortOrder="160"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Secure Token Expiry (Days)</label>
                    <comment>0 means no expiry. Example: 365 for one year validity.</comment>
                </field>

            </group>
        </section>
    </system>
</config>
